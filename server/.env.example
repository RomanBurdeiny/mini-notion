NODE_ENV=development
PORT=3001

# Matches docker-compose.yml (postgres service)
DATABASE_URL="postgresql://mini_notion:mini_notion@localhost:5432/mini_notion?schema=public"

# Integration / E2E tests: copy `.env.test.example` -> `.env.test` (DB `mini_notion_test` is created on first `docker compose up` init)

# JWT — use a long random string in production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
