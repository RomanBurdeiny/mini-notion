generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces    Workspace[]
  authoredPages Page[]    @relation("PageAuthor")
}

model Workspace {
  id        String   @id @default(cuid())
  title     String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  pages Page[]

  @@index([ownerId])
}

model Page {
  id           String  @id @default(cuid())
  title        String
  content      String  @db.Text
  icon         String?
  workspaceId  String
  authorId     String
  parentPageId String?
  isArchived   Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author     User      @relation("PageAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  parentPage Page?     @relation("PageHierarchy", fields: [parentPageId], references: [id], onDelete: SetNull)
  childPages Page[]    @relation("PageHierarchy")

  @@index([workspaceId])
  @@index([authorId])
  @@index([parentPageId])
}
